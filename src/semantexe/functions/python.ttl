@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix py: <http://www.example.com/pythonfunction#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fno: <https://w3id.org/function/ontology#> .
@prefix fnoc: <https://w3id.org/function/vocabulary/composition#> .
@prefix fnom: <https://w3id.org/function/vocabulary/mapping#> .
@prefix ptoi: <https://w3id.org/function/vocabulary/implementation#> .
@prefix ptype: <http://example.com/ptype#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

py:Is a fno:Function ;
      a prov:Entity ;
      rdfs:label "is" ;
      fno:expects [ a rdf:Seq ;
                    rdf:_1 py:ObjectParameter1 ;
                    rdf:_2 py:ObjectParameter2 ] ;
      fno:returns [ a rdf:Seq ;
                    rdf:_1 py:BoolOutput ] ;
      dcterms:description "The is function compares two objects and returns wether the first object is the same as the second object" .

py:IsNot a fno:Function ;
         a prov:Entity ;
         rdfs:label "isNot" ;
         fno:expects [ a rdf:Seq ;
                       rdf:_1 py:ObjectParameter1 ;
                       rdf:_2 py:ObjectParameter2 ] ;
         fno:returns [ a rdf:Seq ;
                       rdf:_1 py:BoolOutput ] ;
         dcterms:description "The is function compares two objects and returns wether the first object is not the same as the second object" .

py:ObjectParameter1 a fno:Parameter ;
                    fno:predicate py:object1 ;
                    fno:type ptype:Any .

py:ObjectParameter2 a fno:Parameter ;
                    fno:predicate py:object2 ;
                    fno:type ptype:Any .

# IF

py:ifexpr a fno:Function ;
          a prov:Entity ;
          fno:expects [ a rdf:Seq ;
                        rdf:_1 py:TestParameter ;
                        rdf:_2 py:IfTrueParameter ;
                        rdf:_3 py:IfFalseParameter ] ;
          fno:returns [ a rdf:Seq ;
                        rdf:_1 py:IfExprOutput ] ;
          dcterms:descrition "ask GPT for description" .

py:TestParameter a fno:Parameter ;
                 fno:predicate py:test ;
                 fno:type ptype:bool .

py:IfTrueParameter a fno:Parameter ;
                   fno:predicate py:trueValue ;
                   fno:type ptype:Any .

py:IfFalseParameter a fno:Parameter ;
                    fno:predicate py:falseValue ;
                    fno:type ptype:Any .

py:IfExprOutput a fno:Output ;
                fno:predicate py:ifExprResult ;
                fno:type ptype:Any .

py:BoolOutput a fno:Output ;
              fno:predicate py:bool ;
              fno:type ptype:bool .

# CONTAINTERS

py:slice a fno:Function ;
         a prov:Entity ;
         rdfs:label "slice" ;
         fno:expects [ a rdf:Seq ;
                       rdf:_1 py:LowerIndexParameter ;
                       rdf:_2 py:UpperIndexParameter ;
                       rdf:_3 py:StepParameter ] ;
         fno:returns [ a rdf:Seq ;
                       rdf:_1 py:SliceOutput ] ;
         dcterms:descrition "Create a slicing object." .

py:LowerIndexParameter a fno:Parameter ;
                       fno:predicate py:lower ;
                       fno:type xsd:integer .

py:UpperIndexParameter a fno:Parameter ;
                       fno:predicate py:upper ;
                       fno:type xsd:integer .

py:StepParameter a fno:Parameter ;
                 fno:predicate py:step ;
                 fno:type xsd:integer .

py:SliceOutput a fno:Output ;
               fno:predicate py:sliceResult ;
               fno:type rdf:Resource .

# CONTAINTERS

py:list a fno:Function ;
      a prov:Entity ;
      rdfs:label "list" ;
      fno:expects [ a rdf:Seq ;
                    rdf:_1 py:Elements ] ;
      fno:returns [ a rdf:Seq ;
                      rdf:_1 py:ListOutput ] ;
      dcterms:descrition "ask GPT for description" .

py:Elements a fno:Parameter ;
            fno:predicate py:elements .

py:ListOutput a fno:Output ;
              fno:predicate py:listResult ;
              fno:type rdf:List .

py:tuple a fno:Function ;
      a prov:Entity ;
      rdfs:label "tuple" ;
      fno:expects [ a rdf:Seq ;
                    rdf:_1 py:Elements ] ;
      fno:returns [ a rdf:Seq ;
                    rdf:_1 py:TupleOutput ] ;
      dcterms:descrition "ask GPT for description" .

py:TupleOutput a fno:Output ;
               fno:predicate py:tupleResult ;
               fno:type rdf:List .

py:dict a fno:Function ;
      a prov:Entity ;
      rdfs:label "dict" ;
      fno:expects [ a rdf:Seq ;
                    rdf:_1 py:Pairs ] ;
      fno:returns [ a rdf:Seq ;
                      rdf:_1 py:DictOutput ] ;
      dcterms:descrition "ask GPT for description" .

py:Pairs a fno:Parameter ;
         fno:predicate py:pairs ;
         fno:type rdf:Seq .

py:DictOutput a fno:Output ;
              fno:predicate py:dictResult ;
              fno:type rdf:Seq .

# FORMAT

py:joinstr a fno:Function ;
      a prov:Entity ;
      rdfs:label "joinstr" ;
      fno:expects [ a rdf:Seq ;
                    rdf:_1 py:Delimiter ;
                    rdf:_2 py:Strings ] ;
      fno:returns [ a rdf:Seq ;
                    rdf:_1 py:JoinStringOutput ] ;
      dcterms:description "Join a list of strings with a given delimiter." .

py:JoinStringOutput a fno:Output ;
    fno:predicate py:joinstrResult ;
    fno:type xsd:string .

py:Strings a fno:Parameter ;
    fno:predicate py:strings ;
    fno:required true ;
    fno:type rdfs:list .

py:Delimiter a fno:Parameter ;
    fno:predicate py:self ;
    fno:required true ;
    fno:type xsd:string .

py:format a fno:Function ;
      a prov:Entity ;
      fno:expects [ a rdf:Seq ;
                    rdf:_1 py:ValueParameter ;
                    rdf:_2 py:ConversionParameter ;
                    rdf:_2 py:SpecParameter ] ;
      fno:returns [ a rdf:Seq ;
                    rdf:_1 py:FormatOutput ] ;
      dcterms:description "Format a value to a string" .

py:ConversionParameter a fno:Parameter ;
      fno:predicate py:conversion ;
      fno:type xsd:string .

py:SpecParameter a fno:Parameter ;
      fno:predicate py:spec ;
      fno:type xsd:string .

py:FormatOutput a fno:Output ;
      fno:predicate py:formatResult ;
      fno:type xsd:string .